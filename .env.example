# CyberSec CLI - Environment Variables Template
# Copy this file to .env and fill in the real values
# NEVER commit .env with real credentials to version control

# =============================================================================
# REQUIRED: API Keys (get from respective service dashboards)
# =============================================================================

# Groq API Key - https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# =============================================================================
# REQUIRED: Database Connection
# =============================================================================

# Neon PostgreSQL connection string - https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# =============================================================================
# REQUIRED: Security Secrets (generate with: openssl rand -hex 32)
# =============================================================================

# Flask/Session secret key - generate with: openssl rand -hex 32
SECRET_KEY=generate-with-openssl-rand-hex-32

# WebSocket authentication key - generate with: openssl rand -hex 32
WEBSOCKET_API_KEY=generate-with-openssl-rand-hex-32

# API key hashing salt (MUST be stable; rotating invalidates existing keys)
API_KEY_SALT=generate-with-openssl-rand-hex-32
# Optional previous salt for transition windows (leave blank when not rotating)
API_KEY_SALT_PREVIOUS=

# =============================================================================
# OPTIONAL: Redis Configuration
# =============================================================================

REDIS_URL=redis://redis:6379/0
REDIS_DB=0
REDIS_PASSWORD=
ENABLE_REDIS=true

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_WORKERS=4

# Scanning defaults
SCAN_DEFAULT_TIMEOUT=2
SCAN_MAX_THREADS=50
SCAN_RATE_LIMIT=10
ADAPTIVE_SCANNING=true

# Rate limiting
CLIENT_RATE_LIMIT=10
TARGET_RATE_LIMIT=50
GLOBAL_RATE_LIMIT=1000
RATE_LIMIT_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Output
OUTPUT_DEFAULT_FORMAT=table
OUTPUT_SAVE_RESULTS=true
OUTPUT_EXPORT_PATH=/app/reports/

# Security
SECURITY_REQUIRE_CONFIRMATION=true
SECURITY_LOG_ALL_COMMANDS=true
SECURITY_ENCRYPT_STORED_DATA=true

# UI
UI_COLOR_OUTPUT=true
UI_SHOW_BANNER=true
CYBERSEC_THEME=matrix

# CORS - explicit origins only (comma-separated, no spaces, no wildcards)
ALLOWED_ORIGINS=https://your-frontend-domain.com,https://your-other-domain.com

# Observability
ENABLE_METRICS=true
METRICS_PORT=9090
DEFAULT_TIMEOUT=3.0
MAX_CONCURRENCY=100
