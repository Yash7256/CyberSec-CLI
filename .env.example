# CyberSec CLI - Environment Variables Template
# Copy this file to .env and fill in the real values
# NEVER commit .env with real credentials to version control

# =============================================================================
# REQUIRED: API Keys (get from respective service dashboards)
# =============================================================================

# Groq API Key - https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# =============================================================================
# REQUIRED: Database Connection
# =============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# PostgreSQL password (must match DATABASE_URL — used by docker-compose postgres service)
# Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=generate-with-openssl-rand-hex-24

# PostgreSQL exporter DSN (used by prometheus postgres-exporter in docker-compose)
DATA_SOURCE_NAME=postgresql://cybersec:your-password@postgres:5432/cybersec?sslmode=disable

# =============================================================================
# REQUIRED: Security Secrets (generate with: openssl rand -hex 32)
# =============================================================================

# Flask/Session secret key - generate with: openssl rand -hex 32
SECRET_KEY=generate-with-openssl-rand-hex-32

# WebSocket authentication key - generate with: openssl rand -hex 32
WEBSOCKET_API_KEY=generate-with-openssl-rand-hex-32

# API key hashing salt (MUST be stable; rotating invalidates existing keys)
API_KEY_SALT=generate-with-openssl-rand-hex-32
# Optional previous salt for transition windows (leave blank when not rotating)
API_KEY_SALT_PREVIOUS=

# =============================================================================
# OPTIONAL: Redis Configuration
# =============================================================================

REDIS_URL=redis://redis:6379/0
REDIS_DB=0
REDIS_PASSWORD=
ENABLE_REDIS=true

# Set to true to make Redis mandatory at startup (recommended for production).
# If true and Redis is unavailable, the app will refuse to start.
REQUIRE_REDIS=false

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_WORKERS=4

# Scanning defaults
SCAN_DEFAULT_TIMEOUT=2
SCAN_MAX_THREADS=50
SCAN_RATE_LIMIT=10
ADAPTIVE_SCANNING=true

# Rate limiting
CLIENT_RATE_LIMIT=10
TARGET_RATE_LIMIT=50
GLOBAL_RATE_LIMIT=1000
RATE_LIMIT_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Output
OUTPUT_DEFAULT_FORMAT=table
OUTPUT_SAVE_RESULTS=true
OUTPUT_EXPORT_PATH=/app/reports/

# Security
SECURITY_REQUIRE_CONFIRMATION=true
SECURITY_LOG_ALL_COMMANDS=true
SECURITY_ENCRYPT_STORED_DATA=true

# UI
UI_COLOR_OUTPUT=true
UI_SHOW_BANNER=true
CYBERSEC_THEME=matrix

# CORS - explicit origins only (comma-separated, no spaces, no wildcards)
ALLOWED_ORIGINS=https://your-frontend-domain.com,https://your-other-domain.com
# =============================================================================
# MONITORING (required if using docker-compose monitoring stack)
# =============================================================================

# Grafana admin password — generate with: openssl rand -hex 16
GF_SECURITY_ADMIN_PASSWORD=generate-with-openssl-rand-hex-16

# =============================================================================
# CVE ENRICHMENT
# =============================================================================

# Set to true to enable live CVE lookups from NVD API.
# WARNING: enabling this sends service/version fingerprints to an external API.
# Disabled by default for privacy.
ENABLE_LIVE_CVE=false

# Observability
ENABLE_METRICS=true
METRICS_PORT=9090
DEFAULT_TIMEOUT=3.0
MAX_CONCURRENCY=100
